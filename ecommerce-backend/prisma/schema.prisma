
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
 
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  image       String
  stock       Int
  
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model User{
   id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Category {
  id        String   @id @default(cuid())
  name      String
  
  products Product[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}